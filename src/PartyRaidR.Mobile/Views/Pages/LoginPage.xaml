<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:PartyRaidR.Mobile.Controls"
             x:Class="PartyRaidR.Mobile.Views.Pages.LoginPage"
             Title="Party RaidR">
    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center">
            <Label Text="Login" Style="{StaticResource Headline}" TextColor="{StaticResource Primary}"/>
            
            <controls:InputTextField Placeholder="Enter your email address!"
                                     IsPassword="False"
                                     Margin="20,20,20,10"/>
            
            <controls:InputTextField Placeholder="Enter your password!"
                                     IsPassword="True"
                                     Margin="20,0,20,10"/>
            <Button Text="Login" Margin="20,5,20,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>