<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PartyRaidR.Mobile.Views.Pages.LoginPage"
             Title="LoginPage">
    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center">
            <Label Text="Login" FontSize="26" HorizontalOptions="Center" TextColor="#5174E9"/>
            <Entry Placeholder="Email" Margin="20,20,20,10" />
            <Entry Placeholder="Password" Margin="20,0" IsPassword="True"/>
            <Button Text="Login" Margin="20,20,20,0" Padding="10" TextTransform="Uppercase" BackgroundColor="#5174E9" TextColor="WhiteSmoke"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>