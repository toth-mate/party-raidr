<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PartyRaidR.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PartyRaidR.Mobile"
    Title="PartyRaidR.Mobile">
    
    <!-- Navigation -->
    <TabBar>
        <Tab Title="Home">
            <ShellContent ContentTemplate="{DataTemplate local:Views.Pages.MainPage}"
              Route="home"/>
        </Tab>
        <Tab Title="Profile">
            <ShellContent ContentTemplate="{DataTemplate local:Views.Pages.LoginPage}"
              Route="profile"/>
        </Tab>
        <Tab Title="Settings">
            <ShellContent ContentTemplate="{DataTemplate local:Views.Pages.LoginPage}"
              Route="settings"/>
        </Tab>
    </TabBar>
    
</Shell>
